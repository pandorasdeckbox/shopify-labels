# Shopify App Credentials (from Shopify Partner Dashboard)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# App URL
# Local dev: use cloudflare tunnel URL (run: npm run tunnel)
# Production: https://labels.pandorasdeckbox.com
APP_URL=https://your-app-url.example.com

PORT=3000
NODE_ENV=development

# Database
# Local dev: leave unset (uses SQLite sessions.db automatically)
# Railway: set to the PostgreSQL connection string from Railway's Postgres plugin
DATABASE_URL=
